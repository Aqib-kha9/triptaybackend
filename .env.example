# ─────────────────────────────────────────────────────────────
# Triptay Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ─── Server ───
NODE_ENV=development
PORT=5000

# ─── Database ───
DATABASE_URL="postgres://user:password@localhost:5432/triptay?sslmode=require"

# ─── JWT ───
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# ─── Admin Seed ───
ADMIN_EMAIL=admin@triptay.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=Admin Name

# ─── App URLs ───
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_URL=https://triptay.com
ADMIN_URL=http://localhost:3001

# ─── Cloudinary (Image uploads) ───
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── AWS S3 (Media storage) ───
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=triptay-media
AWS_S3_PUBLIC_URL=

# ─── AWS SES (Email) ───
AWS_SES_REGION=ap-south-1
SES_FROM_EMAIL=no-reply@triptay.com
SES_FROM_NAME=Triptay
SES_CONFIGURATION_SET=

# ─── AWS SNS (WhatsApp / SMS) ───
AWS_SNS_REGION=ap-south-1

# ─── AWS SQS (Async job processing) ───
AWS_SQS_REGION=ap-south-1
AWS_SQS_QUEUE_URL=
SQS_ENABLED=false

# ─── Razorpay (Primary payment gateway for India) ───
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Stripe (International payments) ───
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_CURRENCY=usd

# ─── PayU (Secondary payment gateway for India) ───
# Get these from your PayU merchant dashboard
PAYU_MERCHANT_ID=your_payu_merchant_id
PAYU_KEY=your_payu_key
PAYU_SALT=your_payu_salt
# Webhook salt is used for server-to-server notification verification
# (may be same as PAYU_SALT if you haven't set a separate one)
PAYU_WEBHOOK_SALT=your_payu_webhook_salt
# Test: https://test.payu.in  |  Production: https://secure.payu.in
PAYU_BASE_URL=https://test.payu.in
# Payment Handle URL (e.g. https://u.payu.in/WrmptyxGODNH)
PAYU_PAYMENT_HANDLE_URL=
# Environment: TEST or PRODUCTION
PAYU_ENV=TEST
# Callback URLs — PayU redirects the user's browser here after payment
# These should point to your frontend
PAYU_SUCCESS_URL=http://localhost:3000/checkout/payu/success
PAYU_FAILURE_URL=http://localhost:3000/checkout/payu/failure

# ─── Firebase (Push notifications) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# ─── WhatsApp Business API (Meta) ───
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=triptay_verify

# ─── Redis (Caching) ───
REDIS_URL=redis://localhost:6379
REDIS_TTL=300

# ─── Commission ───
COMMISSION_RATE=10
MIN_PAYOUT_AMOUNT=500
